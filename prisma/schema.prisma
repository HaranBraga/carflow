generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MULTI-TENANT: Cada empresa terá seu próprio registro aqui.
// No futuro, cada empresa pode ter seu próprio banco de dados.
// Por ora, isolamento por tenantId em todas as tabelas.
// ============================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  cnpj      String?  @unique
  phone     String?
  address   String?
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  customers  Customer[]
  vehicles   Vehicle[]
  orders     ServiceOrder[]
  washers    Washer[]
  services   Service[]
  cashFlows  CashFlow[]
  feedbacks  Feedback[]
  categories ServiceCategory[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         UserRole @default(MANAGER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders ServiceOrder[]

  @@unique([email, tenantId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  ATTENDANT
}

// ============================================================
// CLIENTES
// ============================================================

model Customer {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  phone       String
  gender      Gender      @default(NOT_INFORMED)
  isUber      Boolean     @default(false)
  notes       String?
  qrCodeToken String      @unique @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  feedbacks Feedback[]

  @@map("customers")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_INFORMED
}

// ============================================================
// VEÍCULOS
// ============================================================

model Vehicle {
  id         String          @id @default(cuid())
  tenantId   String
  customerId String
  plate      String
  model      String
  brand      String?
  color      String?
  category   VehicleCategory
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id])
  orders   ServiceOrder[]

  @@unique([plate, tenantId])
  @@map("vehicles")
}

enum VehicleCategory {
  POPULAR
  SUV_MEDIO
  SUV_GRANDE
  CAMIONETE
  VAN_CAMINHAO
  MOTO
  TAPETE_RESIDENCIAL
}

// ============================================================
// SERVIÇOS E CATEGORIAS
// ============================================================

model ServiceCategory {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  active   Boolean @default(true)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("service_categories")
}

model Service {
  id          String  @id @default(cuid())
  tenantId    String
  categoryId  String?
  name        String
  description String?
  basePrice   Decimal @db.Decimal(10, 2)
  active      Boolean @default(true)

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  ServiceCategory? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("services")
}

// ============================================================
// ORDENS DE SERVIÇO (LAVAGEM)
// ============================================================

model ServiceOrder {
  id          String      @id @default(cuid())
  tenantId    String
  vehicleId   String
  managerId   String
  washerId    String?
  status      OrderStatus @default(WAITING)
  notes       String?
  totalAmount Decimal     @db.Decimal(10, 2) @default(0)
  whatsappSent Boolean    @default(false)
  arrivedAt   DateTime    @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  manager     User              @relation(fields: [managerId], references: [id])
  washer      Washer?           @relation(fields: [washerId], references: [id])
  items       OrderItem[]
  checklist   ChecklistItem[]
  opportunities Opportunity[]

  @@map("service_orders")
}

enum OrderStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  serviceId String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @db.Decimal(10, 2) @default(0)
  total     Decimal @db.Decimal(10, 2)
  notes     String?

  order   ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service      @relation(fields: [serviceId], references: [id])

  @@map("order_items")
}

// Checklist de avarias ao receber o carro
model ChecklistItem {
  id       String         @id @default(cuid())
  orderId  String
  area     String
  hasIssue Boolean        @default(false)
  notes    String?
  photoUrl String?

  order ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// Oportunidades de serviço sugeridas ao receber o carro
model Opportunity {
  id          String  @id @default(cuid())
  orderId     String
  description String
  estimatedValue Decimal? @db.Decimal(10, 2)
  contacted   Boolean @default(false)
  notes       String?

  order ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("opportunities")
}

// ============================================================
// LAVADORES AUTÔNOMOS
// ============================================================

model Washer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  cpf       String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   ServiceOrder[]
  payments WasherPayment[]

  @@map("washers")
}

model WasherPayment {
  id        String   @id @default(cuid())
  washerId  String
  amount    Decimal  @db.Decimal(10, 2)
  date      DateTime @default(now())
  notes     String?
  cashFlowId String?

  washer    Washer    @relation(fields: [washerId], references: [id])
  cashFlow  CashFlow? @relation(fields: [cashFlowId], references: [id])

  @@map("washer_payments")
}

// ============================================================
// FLUXO DE CAIXA
// ============================================================

model CashFlow {
  id          String        @id @default(cuid())
  tenantId    String
  date        DateTime      @default(now())
  type        CashFlowType
  category    String
  description String
  amount      Decimal       @db.Decimal(10, 2)
  orderId     String?
  closed      Boolean       @default(false)
  createdAt   DateTime      @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  washerPayments WasherPayment[]

  @@map("cash_flows")
}

enum CashFlowType {
  INCOME
  EXPENSE
}

// ============================================================
// FEEDBACK / AVALIAÇÕES
// ============================================================

model Feedback {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  token       String   @unique @default(cuid())
  rating      Int?     // 0-5
  comment     String?
  isPublic    Boolean  @default(false)
  submittedAt DateTime?
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@map("feedbacks")
}
