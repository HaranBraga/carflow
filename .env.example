# Master DB - guarda lista de empresas + credenciais de login
# Cada empresa tem seu próprio DATABASE_URL cadastrado via /admin
MASTER_DATABASE_URL="postgresql://user:password@localhost:5432/carflow_master"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Admin (página /admin para gerenciar empresas)
ADMIN_SECRET="troque-por-uma-senha-forte-aqui"

# OpenWeather API (global, ainda não é por empresa)
OPENWEATHER_API_KEY="your-openweather-api-key"
OPENWEATHER_CITY="São Paulo"
OPENWEATHER_LAT="-23.5505"
OPENWEATHER_LON="-46.6333"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CarFlow ERP"

# Instagram (link no QR code de feedback)
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/seu_perfil"
