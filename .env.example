# Database - cada empresa terá seu próprio banco no futuro (multi-tenant)
DATABASE_URL="postgresql://user:password@localhost:5432/carflow_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="https://your-evolution-api.com"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_INSTANCE="your-instance-name"

# OpenWeather API
OPENWEATHER_API_KEY="your-openweather-api-key"
OPENWEATHER_CITY="São Paulo"
OPENWEATHER_LAT="-23.5505"
OPENWEATHER_LON="-46.6333"

# Admin (página /admin para gerenciar empresas)
ADMIN_SECRET="troque-por-uma-senha-forte-aqui"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CarFlow ERP"

# Instagram (para QR code de feedback)
INSTAGRAM_URL="https://instagram.com/seu_perfil"
